{
  "name": "gemini-cli-telegram",
  "version": "1.0.8",
  "description": "Connect Gemini CLI to Telegram",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/user/gemini-cli-telegram.git"
  },
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gemini-cli-telegram": "dist/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc --build && mkdir -p dist/config && cp src/config/models.json dist/config/",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@grammyjs/runner": "^2.0.3",
    "better-sqlite3": "^13.0.1",
    "commander": "^15.0.0",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.45.1",
    "lru-cache": "^11.5.2",
    "markdown-it": "^14.1.1",
    "markdown-it-cjk-friendly": "^2.0.2",
    "pino": "^10.3.1",
    "strip-ansi": "^7.1.0",
    "strip-json-comments": "^3.1.1",
    "undici": "^8.5.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/markdown-it": "^14.1.2",
    "@vitest/coverage-v8": "^3.1.1",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.3.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}
