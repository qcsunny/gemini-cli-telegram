{
  "name": "gemini-cli-telegram",
  "version": "0.2.2",
  "description": "Connect Gemini CLI to Telegram",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ibidathoillah/gemini-cli-telegram.git"
  },
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gemini-cli-telegram": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc --build",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@grammyjs/runner": "^2.0.3",
    "grammy": "^1.35.0",
    "markdown-it": "^14.1.1",
    "markdown-it-cjk-friendly": "^2.0.2",
    "strip-ansi": "^7.1.0",
    "strip-json-comments": "^3.1.1",
    "undici": "^8.5.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@vitest/coverage-v8": "^3.1.1",
    "typescript": "^5.3.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}
